# Shopify Certificado Exportação Webhook
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
CERTIFICADO_BASE_URL=https://certificado-exportacao.vercel.app/download

# Webhook Secret (definir no Shopify e aqui para verificar HMAC)
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here
