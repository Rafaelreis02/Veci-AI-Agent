# ============================================
# VECINOCUSTOM INFLUENCER PLATFORM
# Environment Variables Template
# ============================================
# 
# ⚠️ IMPORTANTE:
# - NUNCA commites este ficheiro com valores reais!
# - Copia para .env.local e preenche lá
# - Usa 1Password para gestão segura de secrets
#
# 📖 Documentação: security-report.md
# 🔐 1Password Vault: VecinoCustom
# ============================================

# ============================================
# 1. DATABASE (Obrigatório)
# ============================================
# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Exemplo dev: postgresql://postgres:password@localhost:5432/vecinocustom
# Exemplo prod: postgresql://user:pass@neon.tech/db?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/vecinocustom"

# ============================================
# 2. AUTHENTICATION - NextAuth.js (Obrigatório)
# ============================================
# NEXTAUTH_SECRET: Gerar com: openssl rand -base64 32
# ou: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="generate-a-random-secret-here-min-32-chars"

# NEXTAUTH_URL: URL base da aplicação
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# 3. SHOPIFY INTEGRATION (Recomendado)
# ============================================
# Store URL: nome-da-loja.myshopify.com
SHOPIFY_STORE_URL="your-store.myshopify.com"

# OAuth credentials da app Shopify
# Criar em: Partners Dashboard > Apps > Create app
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""

# URL pública para callbacks OAuth
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ============================================
# 4. CRON JOBS - Proteção (Obrigatório para produção)
# ============================================
# Gerar secret aleatório para proteger endpoints de cron
# Vercel Cron usa este header: Authorization: Bearer CRON_SECRET
CRON_SECRET="generate-a-random-secret-here"

# ============================================
# 5. AI & SCRAPING APIs (Recomendado)
# ============================================
# Apify API Token
# Obter em: https://console.apify.com/account/integrations
APIFY_TOKEN=""

# Anthropic Claude API Key (para análise de influencers)
# Obter em: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# OU Google Gemini API Key (alternativa)
# GOOGLE_GEMINI_API_KEY=""

# ============================================
# 6. EMAIL INTEGRATION (Opcional)
# ============================================
# Opção A: Gmail OAuth (para sincronização de emails)
# Criar credenciais em: Google Cloud Console > APIs & Services > Credentials
GMAIL_CLIENT_SECRET=""

# Opção B: SendGrid (para envio de emails)
SENDGRID_API_KEY=""

# Email de origem para comunicações
FROM_EMAIL="brand@vecinocustom.com"

# ============================================
# 7. FILE STORAGE - AWS S3 / Cloudflare R2 (Opcional)
# ============================================
# Se não configurado, usa Vercel Blob (default)
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-1"

# ============================================
# 8. SOCIAL MEDIA APIs (Futuro)
# ============================================
# TikTok for Business API
# Documentação: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Instagram Basic Display / Graph API
# Documentação: https://developers.facebook.com/docs/instagram
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# ============================================
# 9. MONITORING & ANALYTICS (Opcional)
# ============================================
# Sentry DSN para error tracking
# SENTRY_DSN=""

# Analytics (Google Analytics, Plausible, etc.)
# NEXT_PUBLIC_GA_ID=""

# ============================================
# 10. REDIS / UPSTASH (Opcional - para cache/queues)
# ============================================
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ============================================
# CHECKLIST DE SETUP
# ============================================
# [ ] Copiar este ficheiro para .env.local
# [ ] Preencher DATABASE_URL (dev database)
# [ ] Gerar NEXTAUTH_SECRET
# [ ] Configurar NEXTAUTH_URL
# [ ] (Opcional) Configurar Shopify
# [ ] (Opcional) Configurar Apify
# [ ] (Opcional) Configurar Anthropic/Gemini
# [ ] (Opcional) Configurar Email
# [ ] Testar: npm run dev
# [ ] Verificar logs por erros de configuração
# ============================================
